{
  "name": "radio-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @ra/shared build && pnpm --filter @ra/client build && pnpm --filter @ra/server build",
    "dev": "concurrently -n server,client -c blue,magenta \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "cross-env AUTH_DEV_BYPASS=true DEV_USER_ROLE=admin SERVE_CLIENT=false pnpm --filter @ra/server dev",
    "dev:client": "pnpm --filter @ra/client dev",
    "start": "pnpm --filter @ra/server start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test": "vitest run"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.2.0"
  }
}
