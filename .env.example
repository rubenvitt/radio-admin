# --- Persistence ---
# Path to the SQLite database file. In Docker this lives on the mounted volume.
DATABASE_PATH=/data/data.sqlite

# --- Session (REQUIRED in prod, >=32 chars) ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- OIDC / PocketID (REQUIRED in prod; ignored when AUTH_DEV_BYPASS=true) ---
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://radio-admin.example.org/api/auth/callback
OIDC_ADMIN_GROUP=admin
OIDC_UPDATER_GROUP=personal

# --- Dev bypass (MUST stay false in prod) ---
# When true, authentication is DISABLED and every request runs as the dev user
# below. OIDC_* and SESSION_SECRET become optional in this mode.
AUTH_DEV_BYPASS=false
DEV_USER_ROLE=admin
DEV_USER_NAME=Dev User

# --- Server ---
PORT=3000

# Directory the built SPA is served from. Default ./client/dist (local); the
# Docker image sets this to /app/client/dist.
STATIC_DIR=./client/dist

# Directory holding the committed drizzle migrations. Defaults to a path that
# resolves in both dev and the bundled/Docker layout; the image sets it to
# /app/server/drizzle.
MIGRATIONS_DIR=./server/drizzle
